---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProjects = (await getCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Projects — Fernando Wittmann"
  description="Open-source packages and machine learning research projects"
  lang="en"
  alternateUrl="/projetos"
>
  <div class="max-w-6xl mx-auto">
    <div class="mb-16">
      <h1 class="text-5xl font-bold mb-4">
        <span class="gradient-text">Projects</span>
      </h1>
      <p class="text-xl" style="color: var(--tn-text);">
        Open-source packages and machine learning research projects
      </p>
    </div>

    {allProjects.length === 0 ? (
      <div class="card text-center py-12">
        <p style="color: var(--tn-muted);">No projects published yet.</p>
      </div>
    ) : (
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {allProjects.map((project) => (
          <article class="card group relative overflow-hidden">
            {project.data.image && (
              <div class="mb-4 -mx-6 -mt-6 overflow-hidden rounded-t-xl">
                <img
                  src={project.data.image}
                  alt={project.data.title}
                  class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-300"
                />
              </div>
            )}
            <div class="flex items-start justify-between mb-4">
              <div class="p-2.5 rounded-lg" style="background-color: rgba(122, 162, 247, 0.1); border: 1px solid rgba(122, 162, 247, 0.2);">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--tn-blue);">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                </svg>
              </div>
              {project.data.featured && (
                <span class="px-3 py-1 text-xs font-medium rounded-full" style="background-color: rgba(224, 175, 104, 0.15); color: var(--tn-yellow); border: 1px solid rgba(224, 175, 104, 0.25);">
                  Featured
                </span>
              )}
            </div>
            <h2 class="text-xl font-bold mb-3 group-hover:gradient-text transition-all" style="color: var(--tn-text-bright);">
              {project.data.title}
            </h2>
            <p class="text-sm mb-4" style="color: var(--tn-text);">{project.data.description}</p>
            <div class="flex flex-wrap gap-2 mb-6">
              {project.data.tech.map(tech => <span class="tech-badge">{tech}</span>)}
            </div>
            <div class="flex gap-4 text-sm pt-4" style="border-top: 1px solid var(--tn-border);">
              {project.data.github && (
                <a href={project.data.github} target="_blank" rel="noopener noreferrer"
                   class="font-medium flex items-center gap-1 transition-colors"
                   style="color: var(--tn-blue);">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                  </svg>
                  Code
                </a>
              )}
              {project.data.demo && (
                <a href={project.data.demo} target="_blank" rel="noopener noreferrer"
                   class="font-medium flex items-center gap-1 transition-colors"
                   style="color: var(--tn-cyan);">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                  Demo
                </a>
              )}
            </div>
          </article>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
