---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog'))
  .filter(post => !post.data.draft && post.data.lang === 'en')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const featuredProjects = (await getCollection('projects'))
  .filter(project => project.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const skills = [
  'Python', 'TensorFlow', 'PyTorch', 'Scikit-learn',
  'Deep Learning', 'NLP', 'Computer Vision', 'MLOps',
  'AWS', 'GCP', 'PySpark', 'Databricks',
];

const stats = [
  { value: '10+', label: 'Years of experience' },
  { value: '500+', label: 'Students mentored' },
  { value: 'Top 4%', label: 'Stack Overflow (Python)' },
  { value: 'Silver', label: 'Kaggle medal' },
];
---

<BaseLayout
  title="Fernando Wittmann — Senior ML Engineer"
  description="Senior Machine Learning Engineer specializing in Deep Learning, Recommender Systems, NLP, and Computer Vision."
  lang="en"
  alternateUrl="/pt/"
>
  <!-- Hero -->
  <section class="mb-24 pt-16">
    <div class="mb-5">
      <span class="inline-block px-4 py-1.5 rounded-full text-sm font-medium badge-role">
        Senior ML Engineer · Factored (Andrew Ng)
      </span>
    </div>
    <h1 class="text-6xl md:text-7xl font-bold mb-6 leading-tight" style="color: var(--tn-text-bright);">
      Hi, I'm <span class="gradient-text">Fernando Wittmann</span>
    </h1>
    <p class="text-xl mb-10 max-w-2xl leading-relaxed" style="color: var(--tn-text);">
      Senior Machine Learning Engineer with 10+ years of experience in Deep Learning,
      Recommender Systems, NLP, and Computer Vision. Currently providing ML &amp; GenAI
      consulting for S&amp;P 600 companies at Factored.
    </p>
    <div class="flex flex-wrap gap-4 mb-10">
      <a href="/blog" class="btn btn-primary">View Blog →</a>
      <a href="/projects" class="btn btn-secondary">View Projects</a>
    </div>
    <div class="flex flex-wrap gap-2">
      {skills.map(skill => <span class="tech-badge">{skill}</span>)}
    </div>
  </section>

  <!-- Stats -->
  <section class="mb-24">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {stats.map(({ value, label }) => (
        <div class="card text-center py-6">
          <p class="text-3xl font-bold gradient-text mb-1">{value}</p>
          <p class="text-sm" style="color: var(--tn-muted);">{label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Recent Posts -->
  <section class="mb-24">
    <div class="flex items-center justify-between mb-10">
      <h2 class="text-4xl font-bold" style="color: var(--tn-text-bright);">
        Recent <span class="gradient-text">Posts</span>
      </h2>
      <a href="/blog" class="text-sm font-medium transition-colors" style="color: var(--tn-blue);">
        View all →
      </a>
    </div>
    {allPosts.length === 0 ? (
      <div class="card text-center py-12">
        <p style="color: var(--tn-muted);">No posts published yet.</p>
      </div>
    ) : (
      <div style="border-top: 1px solid var(--tn-border);">
        {allPosts.map((post) => (
          <article class="group py-6" style="border-bottom: 1px solid var(--tn-border);">
            <a href={`/blog/${post.slug}`} class="block">
              <div class="flex items-center gap-3 mb-2 text-xs" style="color: var(--tn-muted);">
                <time datetime={post.data.pubDate.toISOString()}>
                  {new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric' }).format(post.data.pubDate)}
                </time>
                {post.data.tags && post.data.tags.length > 0 && (
                  <>
                    <span>·</span>
                    <div class="flex gap-2">
                      {post.data.tags.map(tag => <span class="tag">{tag}</span>)}
                    </div>
                  </>
                )}
              </div>
              <h3 class="text-lg font-bold mb-1 transition-colors group-hover:text-[var(--accent)]" style="color: var(--tn-text-bright);">
                {post.data.title}
              </h3>
              <p class="text-sm line-clamp-2" style="color: var(--tn-text);">{post.data.description}</p>
            </a>
          </article>
        ))}
      </div>
    )}
  </section>

  <!-- Featured Projects -->
  {featuredProjects.length > 0 && (
    <section class="mb-20">
      <div class="flex items-center justify-between mb-10">
        <h2 class="text-4xl font-bold" style="color: var(--tn-text-bright);">
          Featured <span class="gradient-text">Projects</span>
        </h2>
        <a href="/projects" class="text-sm font-medium transition-colors" style="color: var(--tn-blue);">
          View all →
        </a>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {featuredProjects.map((project) => (
          <article class="card group">
            <div class="flex items-start justify-between mb-4">
              <div class="p-2.5 rounded-lg" style="background-color: rgba(122, 162, 247, 0.1); border: 1px solid rgba(122, 162, 247, 0.2);">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--tn-blue);">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                </svg>
              </div>
            </div>
            <h3 class="text-xl font-bold mb-3 group-hover:gradient-text transition-all" style="color: var(--tn-text-bright);">
              {project.data.title}
            </h3>
            <p class="text-sm mb-4" style="color: var(--tn-text);">{project.data.description}</p>
            <div class="flex flex-wrap gap-2 mb-6">
              {project.data.tech.map(tech => <span class="tech-badge">{tech}</span>)}
            </div>
            <div class="flex gap-4 text-sm pt-4" style="border-top: 1px solid var(--tn-border);">
              {project.data.github && (
                <a href={project.data.github} target="_blank" rel="noopener noreferrer"
                   class="font-medium flex items-center gap-1 transition-colors"
                   style="color: var(--tn-blue);">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                  </svg>
                  Code
                </a>
              )}
              {project.data.demo && (
                <a href={project.data.demo} target="_blank" rel="noopener noreferrer"
                   class="font-medium flex items-center gap-1 transition-colors"
                   style="color: var(--tn-cyan);">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                  Demo
                </a>
              )}
            </div>
          </article>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
