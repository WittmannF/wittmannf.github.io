---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Resume — Fernando Wittmann"
  description="Senior ML Engineer with 10+ years of experience. Career history, education, skills, and awards."
  lang="en"
  alternateUrl="/pt/resume"
>
  <div class="max-w-4xl mx-auto">

    <!-- Header -->
    <div class="mb-12">
      <h1 class="text-5xl font-bold mb-4">
        <span class="gradient-text">Resume</span>
      </h1>
      <p class="text-xl" style="color: var(--tn-text);">
        Senior ML Engineer · 10+ years in ML, Deep Learning, NLP & Computer Vision
      </p>
    </div>

    <!-- Experience -->
    <section class="mb-14">
      <h2 class="text-2xl font-bold mb-6" style="color: var(--tn-text-bright);">Experience</h2>
      <div class="space-y-4">

        <div class="card">
          <div class="flex items-start justify-between mb-2 flex-wrap gap-2">
            <div>
              <h3 class="text-lg font-semibold" style="color: var(--tn-text-bright);">Senior ML Engineer</h3>
              <p class="font-medium" style="color: var(--accent);">Factored (factored.ai)</p>
            </div>
            <span class="text-sm" style="color: var(--tn-muted);">Aug 2024 – Present</span>
          </div>
          <p class="text-sm mb-3" style="color: var(--tn-text);">
            Factored is an AI consulting firm co-founded by Andrew Ng, specializing in ML, data engineering, and scalable AI solutions. Currently providing ML and generative AI consulting for an S&P 600 client.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="tech-badge">ML</span><span class="tech-badge">GenAI</span><span class="tech-badge">Python</span>
          </div>
        </div>

        <div class="card">
          <div class="flex items-start justify-between mb-2 flex-wrap gap-2">
            <div>
              <h3 class="text-lg font-semibold" style="color: var(--tn-text-bright);">Senior ML Engineer</h3>
              <p class="font-medium" style="color: var(--accent);">Upflex (upflex.com)</p>
            </div>
            <span class="text-sm" style="color: var(--tn-muted);">Aug 2022 – Jul 2024</span>
          </div>
          <p class="text-sm mb-3" style="color: var(--tn-text);">
            Developed and deployed ML models for pricing prediction, including a recommendation engine for base and product rates. Built a tier model for 100+ locations, a synthetic employee distribution model, and a PDF scraper with NLP capabilities to extract contract data.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="tech-badge">Pricing ML</span><span class="tech-badge">NLP</span><span class="tech-badge">Recommender Systems</span>
          </div>
        </div>

        <div class="card">
          <div class="flex items-start justify-between mb-2 flex-wrap gap-2">
            <div>
              <h3 class="text-lg font-semibold" style="color: var(--tn-text-bright);">Deep Learning Consultant</h3>
              <p class="font-medium" style="color: var(--accent);">VL Corrêa Tecnologia</p>
            </div>
            <span class="text-sm" style="color: var(--tn-muted);">Sep 2023 – Present</span>
          </div>
          <p class="text-sm mb-3" style="color: var(--tn-text);">
            Built a RAG-based chatbot, computer vision solution for retail, and a fraud detection pipeline.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="tech-badge">RAG</span><span class="tech-badge">Computer Vision</span><span class="tech-badge">Fraud Detection</span>
          </div>
        </div>

        <div class="card">
          <div class="flex items-start justify-between mb-2 flex-wrap gap-2">
            <div>
              <h3 class="text-lg font-semibold" style="color: var(--tn-text-bright);">Deep Learning SME & Learning Facilitator</h3>
              <p class="font-medium" style="color: var(--accent);">MITxPro</p>
            </div>
            <span class="text-sm" style="color: var(--tn-muted);">Aug 2023 – Feb 2024</span>
          </div>
          <p class="text-sm mb-3" style="color: var(--tn-text);">
            Reviewed Portuguese translation of the Deep Learning program. Supervised cohorts of 40–50 students, graded assignments, conducted bi-weekly office hours, and provided individual tutoring.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="tech-badge">Deep Learning</span><span class="tech-badge">Teaching</span><span class="tech-badge">PT Translation</span>
          </div>
        </div>

        <div class="card">
          <div class="flex items-start justify-between mb-2 flex-wrap gap-2">
            <div>
              <h3 class="text-lg font-semibold" style="color: var(--tn-text-bright);">Senior ML Engineer</h3>
              <p class="font-medium" style="color: var(--accent);">On Deck (beondeck.com)</p>
            </div>
            <span class="text-sm" style="color: var(--tn-muted);">Nov 2021 – Jul 2022</span>
          </div>
          <p class="text-sm mb-3" style="color: var(--tn-text);">
            Improved a recommender system for co-founder matchmaking. Designed an NLP scoring API, topic modeling of community Slack data, and an ML-based NPS predictor.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="tech-badge">NLP</span><span class="tech-badge">DistilBERT</span><span class="tech-badge">SHAP</span><span class="tech-badge">Recommender Systems</span>
          </div>
        </div>

        <div class="card">
          <div class="flex items-start justify-between mb-2 flex-wrap gap-2">
            <div>
              <h3 class="text-lg font-semibold" style="color: var(--tn-text-bright);">Data Scientist Consultant</h3>
              <p class="font-medium" style="color: var(--accent);">Charm.io</p>
            </div>
            <span class="text-sm" style="color: var(--tn-muted);">Sep 2021 – Oct 2022</span>
          </div>
          <p class="text-sm mb-3" style="color: var(--tn-text);">
            Built PySpark pipelines to extract ResNet features from millions of brand images. Built a product taxonomy classification model for 5k+ labels.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="tech-badge">PySpark</span><span class="tech-badge">ResNet</span><span class="tech-badge">AWS EMR</span><span class="tech-badge">MLFlow</span>
          </div>
        </div>

        <div class="card">
          <div class="flex items-start justify-between mb-2 flex-wrap gap-2">
            <div>
              <h3 class="text-lg font-semibold" style="color: var(--tn-text-bright);">Head of Data Science</h3>
              <p class="font-medium" style="color: var(--accent);">Awari</p>
            </div>
            <span class="text-sm" style="color: var(--tn-muted);">Apr 2020 – Aug 2021</span>
          </div>
          <p class="text-sm mb-3" style="color: var(--tn-text);">
            Founding member of the data science department at an e-learning startup. Led monthly cohorts, developed course material, expanded the program internationally, and managed 30+ mentors.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="tech-badge">Leadership</span><span class="tech-badge">MLOps</span><span class="tech-badge">Teaching</span>
          </div>
        </div>

        <div class="card">
          <div class="flex items-start justify-between mb-2 flex-wrap gap-2">
            <div>
              <h3 class="text-lg font-semibold" style="color: var(--tn-text-bright);">ML Consultant</h3>
              <p class="font-medium" style="color: var(--accent);">Arc.dev / Codementor</p>
            </div>
            <span class="text-sm" style="color: var(--tn-muted);">Jan 2020 – Dec 2021</span>
          </div>
          <p class="text-sm mb-3" style="color: var(--tn-text);">
            Multiple AI projects including a real estate valuation model (error reduced from 25% to 8%), NLP mentoring (Word2Vec, CNNs, LSTMs), and clustering analysis for climate data.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="tech-badge">CatBoost</span><span class="tech-badge">MLFlow</span><span class="tech-badge">BERT</span><span class="tech-badge">Databricks</span>
          </div>
        </div>

        <div class="card">
          <div class="flex items-start justify-between mb-2 flex-wrap gap-2">
            <div>
              <h3 class="text-lg font-semibold" style="color: var(--tn-text-bright);">Senior ML Mentor</h3>
              <p class="font-medium" style="color: var(--accent);">Udacity</p>
            </div>
            <span class="text-sm" style="color: var(--tn-muted);">Jan 2016 – Dec 2021</span>
          </div>
          <p class="text-sm mb-3" style="color: var(--tn-text);">
            Reviewed submissions and mentored 500+ students in ML and Deep Learning nanodegrees. Recorded webinars in both English and Portuguese. Promoted to auditor of other reviewers.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="tech-badge">PyTorch</span><span class="tech-badge">TensorFlow</span><span class="tech-badge">Teaching</span>
          </div>
        </div>

        <div class="card">
          <div class="flex items-start justify-between mb-2 flex-wrap gap-2">
            <div>
              <h3 class="text-lg font-semibold" style="color: var(--tn-text-bright);">Business Intelligence Intern</h3>
              <p class="font-medium" style="color: var(--accent);">Itaipu Hydroelectric Power Plant</p>
            </div>
            <span class="text-sm" style="color: var(--tn-muted);">Jan 2013 – Sep 2013</span>
          </div>
          <p class="text-sm" style="color: var(--tn-text);">
            Developed BI solutions to extract insights from millions of measurements from the world's largest energy generator.
          </p>
        </div>

      </div>
    </section>

    <!-- Education -->
    <section class="mb-14">
      <h2 class="text-2xl font-bold mb-6" style="color: var(--tn-text-bright);">Education</h2>
      <div class="space-y-4">

        <div class="card">
          <div class="flex items-start justify-between mb-1 flex-wrap gap-2">
            <div>
              <h3 class="text-lg font-semibold" style="color: var(--tn-text-bright);">Deep Learning Certificate — FastAI Part II</h3>
              <p class="font-medium" style="color: var(--accent);">University of San Francisco</p>
            </div>
            <span class="text-sm" style="color: var(--tn-muted);">2019</span>
          </div>
          <p class="text-sm" style="color: var(--tn-text);">Awarded a fellowship to attend in-person classes. Course taught by Jeremy Howard, past president of Kaggle.</p>
        </div>

        <div class="card">
          <div class="flex items-start justify-between mb-1 flex-wrap gap-2">
            <div>
              <h3 class="text-lg font-semibold" style="color: var(--tn-text-bright);">MSc in Electrical Engineering</h3>
              <p class="font-medium" style="color: var(--accent);">University of Campinas (UNICAMP)</p>
            </div>
            <span class="text-sm" style="color: var(--tn-muted);">2015 – 2017</span>
          </div>
          <p class="text-sm" style="color: var(--tn-text);">ML and optimization applied to Non-Intrusive Load Monitoring (NILM). Proposed a new algorithm based on Mixed-Integer Linear Programming. Published in IEEE Journal.</p>
        </div>

        <div class="card">
          <div class="flex items-start justify-between mb-1 flex-wrap gap-2">
            <div>
              <h3 class="text-lg font-semibold" style="color: var(--tn-text-bright);">Summer Research Program</h3>
              <p class="font-medium" style="color: var(--accent);">Carnegie Mellon University</p>
            </div>
            <span class="text-sm" style="color: var(--tn-muted);">Jun – Sep 2014</span>
          </div>
          <p class="text-sm" style="color: var(--tn-text);">Applied ML to classify methods for tracking maximum power efficiency in solar photovoltaic systems.</p>
        </div>

        <div class="card">
          <div class="flex items-start justify-between mb-1 flex-wrap gap-2">
            <div>
              <h3 class="text-lg font-semibold" style="color: var(--tn-text-bright);">Exchange Program</h3>
              <p class="font-medium" style="color: var(--accent);">Cal Poly San Luis Obispo</p>
            </div>
            <span class="text-sm" style="color: var(--tn-muted);">Sep 2013 – Jun 2014</span>
          </div>
          <p class="text-sm" style="color: var(--tn-text);">Awarded by the Brazil Scientific Mobility Program. Courses in engineering, CS, and entrepreneurship.</p>
        </div>

        <div class="card">
          <div class="flex items-start justify-between mb-1 flex-wrap gap-2">
            <div>
              <h3 class="text-lg font-semibold" style="color: var(--tn-text-bright);">BSc in Electrical Engineering</h3>
              <p class="font-medium" style="color: var(--accent);">Western Paraná State University (UNIOESTE)</p>
            </div>
            <span class="text-sm" style="color: var(--tn-muted);">2009 – 2014</span>
          </div>
          <p class="text-sm" style="color: var(--tn-text);">Dissertation on Business Intelligence applied to Itaipu Power Plant production data.</p>
        </div>

      </div>
    </section>

    <!-- Skills -->
    <section class="mb-14">
      <h2 class="text-2xl font-bold mb-6" style="color: var(--tn-text-bright);">Skills</h2>
      <div class="card space-y-4">
        <div>
          <p class="text-sm font-semibold mb-2" style="color: var(--tn-text-bright);">ML / DL</p>
          <div class="flex flex-wrap gap-2">
            {['Scikit-learn', 'TensorFlow', 'PyTorch', 'HuggingFace', 'FastAI', 'CatBoost', 'XGBoost', 'LightGBM'].map(s => <span class="tech-badge">{s}</span>)}
          </div>
        </div>
        <div>
          <p class="text-sm font-semibold mb-2" style="color: var(--tn-text-bright);">Data & MLOps</p>
          <div class="flex flex-wrap gap-2">
            {['Pandas', 'NumPy', 'PySpark', 'Airflow', 'Databricks', 'MLFlow'].map(s => <span class="tech-badge">{s}</span>)}
          </div>
        </div>
        <div>
          <p class="text-sm font-semibold mb-2" style="color: var(--tn-text-bright);">Cloud</p>
          <div class="flex flex-wrap gap-2">
            {['AWS (EC2, S3, EMR, Lambda, Redshift)', 'GCP', 'Snowflake'].map(s => <span class="tech-badge">{s}</span>)}
          </div>
        </div>
        <div>
          <p class="text-sm font-semibold mb-2" style="color: var(--tn-text-bright);">Languages & Tools</p>
          <div class="flex flex-wrap gap-2">
            {['Python', 'SQL', 'AMPL', 'Matlab', 'Docker', 'FastAPI', 'Git', 'Streamlit', 'Selenium'].map(s => <span class="tech-badge">{s}</span>)}
          </div>
        </div>
      </div>
    </section>

    <!-- Awards -->
    <section class="mb-14">
      <h2 class="text-2xl font-bold mb-6" style="color: var(--tn-text-bright);">Awards & Achievements</h2>
      <div class="card">
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <span style="color: var(--tn-yellow);" class="mt-0.5">★</span>
            <span class="text-sm" style="color: var(--tn-text);">Top 4% Stack Overflow contributor in Python — over 3M people reached</span>
          </li>
          <li class="flex items-start gap-3">
            <span style="color: var(--tn-yellow);" class="mt-0.5">★</span>
            <span class="text-sm" style="color: var(--tn-text);">Silver medal (top 1.3%) — Kaggle ASHRAE Energy Predictor competition</span>
          </li>
          <li class="flex items-start gap-3">
            <span style="color: var(--tn-yellow);" class="mt-0.5">★</span>
            <span class="text-sm" style="color: var(--tn-text);">3rd place — Chaordic Machine Learning Challenge (2016)</span>
          </li>
          <li class="flex items-start gap-3">
            <span style="color: var(--tn-yellow);" class="mt-0.5">★</span>
            <span class="text-sm" style="color: var(--tn-text);">FastAI fellowship — University of San Francisco in-person program (2019)</span>
          </li>
          <li class="flex items-start gap-3">
            <span style="color: var(--tn-yellow);" class="mt-0.5">★</span>
            <span class="text-sm" style="color: var(--tn-text);">One-year exchange program at Cal Poly SLO — Brazil Scientific Mobility Program (2013)</span>
          </li>
        </ul>
      </div>
    </section>

  </div>
</BaseLayout>
