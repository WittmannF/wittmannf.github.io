---
interface Props {
  lang?: 'en' | 'pt';
  alternateUrl?: string;
}

const { lang = 'en', alternateUrl } = Astro.props;
const currentPath = Astro.url.pathname;

const nav = lang === 'en'
  ? [
      { href: '/', label: 'Home' },
      { href: '/blog', label: 'Blog' },
      { href: '/projects', label: 'Projects' },
    ]
  : [
      { href: '/pt/', label: 'Início' },
      { href: '/pt/blog', label: 'Blog' },
      { href: '/pt/projects', label: 'Projetos' },
    ];

const altLabel = lang === 'en' ? 'PT' : 'EN';
const altUrl = alternateUrl ?? (lang === 'en' ? '/pt/' : '/');

function isActive(href: string) {
  if (href === '/' || href === '/pt/') return currentPath === href;
  return currentPath.startsWith(href);
}
---

<header style="border-bottom: 1px solid var(--tn-border); background-color: rgba(26, 27, 46, 0.85);" class="backdrop-blur-xl sticky top-0 z-50">
  <nav class="container py-5">
    <div class="flex items-center justify-between">
      <a href={lang === 'en' ? '/' : '/pt/'} class="text-xl font-bold transition-colors" style="color: var(--accent);">
        Fernando Wittmann
      </a>
      <div class="flex items-center gap-8">
        <ul class="flex gap-8 text-sm font-medium">
          {nav.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class:list={["nav-link", isActive(href) && "active"]}
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
        <a href={altUrl} class="lang-switcher">
          {altLabel}
        </a>
      </div>
    </div>
  </nav>
</header>
